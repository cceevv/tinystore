{
  "name": "@cceevv/tinystore",
  "version": "2.0.0-beta.1",
  "description": "Tiny React state manager with explicit actions, readonly state, and selective subscriptions.",
  "keywords": [
    "react",
    "hooks",
    "store",
    "state",
    "tiny",
    "tinystore",
    "selector",
    "actions"
  ],
  "license": "MIT",
  "author": "cceevv <cceevv@163.com> (https://github.com/cceevv)",
  "packageManager": "pnpm@10.13.1",
  "homepage": "https://github.com/cceevv/tinystore",
  "repository": "github:cceevv/tinystore",
  "bugs": "https://github.com/cceevv/tinystore/issues",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "test": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "prebuild": "rm -rf dist coverage",
    "build": "tsup src/index.ts --format esm,cjs --dts --clean"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.6.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^3.2.4",
    "happy-dom": "^20.0.10",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tslib": "^2.8.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^3.2.4"
  }
}
